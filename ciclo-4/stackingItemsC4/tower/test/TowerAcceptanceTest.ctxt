#BlueJ class context
comment0.target=TowerAcceptanceTest
comment0.text=\r\n\ TowerAcceptanceTest\ -\ Pruebas\ de\ aceptacion\ del\ ciclo\ 1.\r\n\ Estas\ pruebas\ son\ VISIBLES\ y\ tienen\ delays\ para\ poder\ ver\r\n\ cada\ accion\ sobre\ el\ simulador.\r\n\r\n\ @author\ Daniel\ Felipe\ Sua\ y\ Juan\ David\ Munar\r\n
comment1.params=
comment1.target=void\ pause()
comment1.text=\r\n\ Pausa\ la\ ejecucion\ el\ tiempo\ indicado\ en\ ms.\r\n
comment10.params=
comment10.target=void\ accordingMSAcceptanceReverseTowerInvertsOrder()
comment10.text=\r\n\ Se\ espera\ ver\:\ tazas\ 1,\ 2,\ 3\ de\ abajo\ a\ arriba,\ luego\ se\ invierten\r\n\ quedando\ 3,\ 2,\ 1\ de\ abajo\ a\ arriba.\r\n
comment11.params=
comment11.target=void\ accordingMSAcceptanceMakeInvisibleAndVisible()
comment11.text=\r\n\ Se\ espera\ ver\:\ torre\ con\ tazas,\ luego\ desaparece,\ luego\ reaparece.\r\n
comment12.params=
comment12.target=void\ accordingMSAcceptanceTowerTooBigDoesNotShow()
comment12.text=\r\n\ Se\ espera\ ver\:\ NO\ aparece\ ninguna\ ventana\ porque\ la\ torre\ no\ cabe\r\n\ en\ la\ pantalla.\ ok()\ debe\ ser\ false.\r\n
comment13.params=
comment13.target=void\ accordingMSAcceptancePopCupAlsoRemovesItsLid()
comment13.text=\r\n\ Se\ espera\ ver\:\ taza\ 2\ con\ su\ tapa,\ al\ hacer\ popCup\ ambas\ desaparecen.\r\n
comment2.params=
comment2.target=void\ accordingMSAcceptancePushCupsInOrder()
comment2.text=\r\n\ Se\ espera\ ver\:\ taza\ 1\ (roja),\ luego\ taza\ 2\ (azul)\ encima,\r\n\ luego\ taza\ 3\ (verde)\ encima.\ Cada\ una\ mas\ ancha\ que\ la\ anterior.\r\n
comment3.params=
comment3.target=void\ accordingMSAcceptanceSmallCupNestsInsideBigCup()
comment3.text=\r\n\ Se\ espera\ ver\:\ taza\ 3\ (grande),\ luego\ taza\ 1\ (pequena)\ anidada\ dentro.\r\n\ La\ taza\ 1\ solo\ debe\ sobresalir\ 1\ cm\ por\ encima\ de\ la\ taza\ 3.\r\n
comment4.params=
comment4.target=void\ accordingMSAcceptancePopCupRemovesTopCup()
comment4.text=\r\n\ Se\ espera\ ver\:\ tres\ tazas\ apiladas,\ luego\ la\ del\ tope\ desaparece.\r\n
comment5.params=
comment5.target=void\ accordingMSAcceptanceRemoveCupFromMiddle()
comment5.text=\r\n\ Se\ espera\ ver\:\ tazas\ 1,\ 2,\ 3\ apiladas,\ luego\ la\ taza\ 2\ desaparece\r\n\ y\ la\ taza\ 3\ baja\ a\ ocupar\ su\ lugar.\r\n
comment6.params=
comment6.target=void\ accordingMSAcceptancePushLidAppearsOnTopOfCup()
comment6.text=\r\n\ Se\ espera\ ver\:\ taza\ 2\ en\ la\ torre,\ luego\ su\ tapa\ aparece\ encima.\r\n\ La\ tapa\ debe\ tener\ el\ mismo\ color\ que\ la\ taza.\r\n
comment7.params=
comment7.target=void\ accordingMSAcceptancePopLidRemovesTopLid()
comment7.text=\r\n\ Se\ espera\ ver\:\ taza\ 2\ con\ su\ tapa,\ luego\ la\ tapa\ desaparece.\r\n
comment8.params=
comment8.target=void\ accordingMSAcceptanceOrderTowerSortsDescending()
comment8.text=\r\n\ Se\ espera\ ver\:\ tazas\ en\ orden\ aleatorio,\ luego\ se\ reordenan\r\n\ de\ mayor\ (abajo)\ a\ menor\ (arriba).\r\n
comment9.params=
comment9.target=void\ accordingMSAcceptanceOrderTowerKeepsLidOnCup()
comment9.text=\r\n\ Se\ espera\ ver\:\ tazas\ y\ tapas\ desordenadas,\ luego\ al\ ordenar\r\n\ cada\ tapa\ queda\ inmediatamente\ encima\ de\ su\ taza.\r\n
numComments=14
